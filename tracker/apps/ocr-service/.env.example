LLM_FALLBACK_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
# Cle API Ollama (OLLAMA_API_KEYS dans le docker-compose Ollama).
# Laisser vide si Ollama est sur loopback sans auth.
OLLAMA_API_KEY=
OLLAMA_MODEL=moondream
OLLAMA_NUM_CTX=2048
# Limite le nombre de tokens generes par requete. Les reponses attendues sont
# un court JSON ; garder ce plafond bas evite qu'une ligne monopolise le CPU.
OLLAMA_NUM_PREDICT=256
# Controle optionnel pour les modeles "thinking". Les modeles non concernes
# (ex: moondream) ignorent ce reglage.
OLLAMA_THINK=false
# Duree pendant laquelle Ollama garde le modele en memoire apres une requete.
# Sans keep_alive, le modele est decharge apres ~5 min d'inactivite, causant
# un cold-load de plusieurs secondes a chaque appel. Defaut: 30m.
# Formats: "30m", "1h", "-1" (indefiniment), "0" (decharger immediatement),
# ou entier (secondes). Override via OLLAMA_KEEP_ALIVE.
OLLAMA_KEEP_ALIVE=30m
# HTTP timeout (seconds) for each Ollama /api/generate call. Default 300 (5 min).
# A small vision model on CPU can need 60-120s per row; raise if you hit ReadTimeout.
OLLAMA_TIMEOUT_SECONDS=300
# Timeout dedie au chemin player_stats (un seul appel full-image, pas par ligne).
# 90 s est suffisant pour un modele 2B sur CPU ; au-dela le worker uvicorn se
# bloque et le bot Discord finit par dropper la connexion.
OLLAMA_PLAYER_STATS_TIMEOUT_SECONDS=90
# Largeur et hauteur max (px) de l'image envoyee au LLM pour player_stats.
# Une capture 720x1600 genere plus de vision patch tokens qu'un contexte 4096
# peut absorber, ce qui bloque Ollama jusqu'au timeout. 720x960 couvre ~4 lignes.
OLLAMA_PLAYER_STATS_MAX_WIDTH=720
OLLAMA_PLAYER_STATS_MAX_HEIGHT=960
# Stop calling Ollama after this many consecutive failures within a single
# image so the OCR request doesn't hang for minutes when the LLM is OOM/slow.
# Code default if unset: 2.
LLM_MAX_CONSECUTIVE_FAILURES=2
OCR_CONFIDENCE_THRESHOLD=0.75          # seuil global — fallback si variable specifique absente
# noms: confiances structurellement basses sur certaines fonts, d'où la valeur
# volontairement plus basse que le seuil global (code default si absent: 0.75,
# c'est-a-dire OCR_CONFIDENCE_THRESHOLD).
OCR_CONFIDENCE_THRESHOLD_NAME=0.35
# Code default if unset: INFO. debug is noisier but convenient for local dev.
LOG_LEVEL=debug
# Both optional: the dispatcher loads title aliases from
# at_event_types.title_aliases at startup (RLS reserves read access to the
# authenticated role, so the service_role key is required for this -- there
# is no SUPABASE_ANON_KEY here, the anon key is never read by this service).
# Leave both empty to silently fall back to the embedded static alias list.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# SQLite path for the job store. Use /tmp/jobs.db locally if /data is not mounted.
JOBS_DB_PATH=/data/jobs.db

# Advanced / rarely overridden -- code defaults shown, left commented out.
# OCR_BACKEND=tesserocr                        # tesserocr (in-process) or pytesseract (subprocess rollback)
# OCR_TESS_POOL_SIZE=16                        # size of the tesserocr PyTessBaseAPI instance pool
# OCR_NAME_ASCII_FAST_PATH_ENABLED=true        # try a fast ASCII-only OCR pass before the full multilingual one
# OCR_NAME_ASCII_FAST_PATH_MIN_CONF=0.60       # confidence floor to accept the fast-path result
# OCR_FUZZY_TITLE_THRESHOLD=0.82               # similarity floor for matching a screenshot title to a known event type
# OCR_TAB_DETECT_MIN_DELTA=4.0                 # contribution-ranking parser: min pixel delta to detect a tab boundary
