# Discord bot token — create an app at https://discord.com/developers/applications,
# add a Bot, and copy the token here. Enable the "Message Content Intent" under
# Privileged Gateway Intents (required to read screenshot attachments).
DISCORD_BOT_TOKEN=

# Comma-separated Discord channel IDs the bot ingests from — one per alliance.
# Enable Developer Mode in Discord, right-click a channel → "Copy Channel ID".
# Each ID listed here should also have a row in at_alliances.discord_channel_id.
DISCORD_ALLOWED_CHANNEL_IDS=

# Supabase — same project as the frontend. Use the SERVICE ROLE key: it bypasses
# RLS to write the at_* tables. Never expose it client-side / in the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OCR service URL. With docker compose this resolves to the ocr-service container.
OCR_SERVICE_URL=http://ocr-service:8000

# OCR polling budget (a single job can take a while on CPU).
OCR_TIMEOUT_MS=1800000          # 30 min total polling budget for one OCR job
OCR_POLL_INTERVAL_MS=5000       # delay between two GET /jobs/<id>

# Where incoming screenshots are staged (sha256 dedup happens here).
DATA_INBOX_DIR=/data/inbox

LOG_LEVEL=info
